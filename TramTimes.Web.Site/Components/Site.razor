@inject IHttpContextAccessor AccessorService

<!DOCTYPE html>
<html lang="en">

<head>
    <base href="/"/>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover"/>

    <link rel="icon" href="/favicon.svg" type="image/svg+xml"/>
    <link rel="stylesheet" id="kendo-light" href="https://unpkg.com/@@progress/kendo-theme-default@@@(_version)/dist/default-main.css"/>
    <link rel="stylesheet" id="kendo-dark" href="https://unpkg.com/@@progress/kendo-theme-default@@@(_version)/dist/default-main-dark.css"/>
    <link rel="stylesheet" id="custom-light" href="@Assets["css/default-main.css"]"/>
    <link rel="stylesheet" id="custom-dark" href="@Assets["css/default-main-dark.css"]"/>
    <link rel="stylesheet" id="local-common" href="@Assets["TramTimes.Web.Site.styles.css"]"/>

    <HeadOutlet @rendermode="new InteractiveServerRenderMode(prerender: false)"/>

    <script>
        (function() {
            let scheme = "@_scheme"

            scheme = (scheme === "system")
                ? window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light"
                : scheme;

            setScheme(scheme);
        })();

        function setScheme(scheme) {
            const stylesheets = {
                light: ["kendo-light", "custom-light"],
                dark: ["kendo-dark", "custom-dark"]
            };

            const matches = window.matchMedia("(prefers-color-scheme: dark)").matches;

            if (scheme === "system") {
                stylesheets.light.forEach(id => document.getElementById(id).disabled = matches);
                stylesheets.dark.forEach(id => document.getElementById(id).disabled = !matches);
            } else {
                stylesheets.light.forEach(id => document.getElementById(id).disabled = scheme !== "light");
                stylesheets.dark.forEach(id => document.getElementById(id).disabled = scheme !== "dark");
            }
        }

        window.setScheme = setScheme;
    </script>

    <script src="_content/Telerik.UI.for.Blazor/js/telerik-blazor.js" defer></script>
    <script src="_framework/blazor.web.js" defer></script>
</head>

<body>
    <Routes @rendermode="new InteractiveServerRenderMode(prerender: false)"/>
</body>

</html>

@code {
    private string _scheme = "system";
    private string _version = "latest";

    protected override void OnInitialized()
    {
        _scheme = _scheme is "system"
            ? AccessorService.HttpContext?.Request.Cookies[".AspNet.Preference.Scheme"] ?? "system"
            : _scheme;

        if (_scheme is not "dark" and not "light")
            _scheme = "system";

        _version = AppDomain.CurrentDomain.GetAssemblies()
            .FirstOrDefault(predicate: assembly => assembly.GetName().Name == "Telerik.Blazor")?
            .GetCustomAttribute<AssemblyInformationalVersionAttribute>()?.InformationalVersion
            .Split(separator: "+")
            .First() ?? "latest";
    }
}