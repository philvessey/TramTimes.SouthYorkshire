@inject IHttpContextAccessor AccessorService

<!DOCTYPE html>
<html lang="en">

@code {
    private const string KendoBaseHref = "https://unpkg.com/@progress/kendo-theme-default";
    private string KendoLightHref => $"{KendoBaseHref}@{_version}/dist/default-main.css";
    private string KendoDarkHref => $"{KendoBaseHref}@{_version}/dist/default-main-dark.css";
}

<head>
    <base href="/"/>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover"/>

    <script>
        window.handleError = function (link, fileName) {
            const failedHref = link.href;

            if (link.dataset.fallbackTried === "1") {
                console.error("Kendo CSS fallback failed.", {
                    failedHref: failedHref,
                    fileName: fileName
                });

                return;
            }

            const fallbackHref = "https://unpkg.com/@@progress/kendo-theme-default@@latest/dist/" + fileName;

            console.warn("Kendo CSS failed to load. Falling back to latest.", {
                failedHref: failedHref,
                fallbackHref: fallbackHref,
                fileName: fileName
            });

            link.dataset.fallbackTried = "1";
            link.href = fallbackHref;
        };

        window.setScheme = function (scheme) {
            const stylesheets = {
                light: ["kendo-light", "custom-light"],
                dark: ["kendo-dark", "custom-dark"]
            };

            const matches = window.matchMedia("(prefers-color-scheme: dark)").matches;

            if (scheme === "system") {
                stylesheets.light.forEach(id => {
                    const element = document.getElementById(id);

                    if (element) {
                        element.disabled = matches;
                    }
                });

                stylesheets.dark.forEach(id => {
                    const element = document.getElementById(id);

                    if (element) {
                        element.disabled = !matches;
                    }
                });
            } else {
                stylesheets.light.forEach(id => {
                    const element = document.getElementById(id);

                    if (element) {
                        element.disabled = scheme !== "light";
                    }
                });

                stylesheets.dark.forEach(id => {
                    const element = document.getElementById(id);

                    if (element) {
                        element.disabled = scheme !== "dark";
                    }
                });
            }

            const icon = document.getElementById("local-favicon");

            if (icon) {
                if (scheme === "system") {
                    icon.href = matches
                        ? "/favicon-main-dark.svg"
                        : "/favicon-main.svg";
                } else {
                    icon.href = scheme === "dark"
                        ? "/favicon-main-dark.svg"
                        : "/favicon-main.svg";
                }
            }
        };
    </script>

    <link rel="icon"
          id="local-favicon"
          href="/favicon.svg"
          type="image/svg+xml"/>

    <link rel="stylesheet"
          id="kendo-light"
          href="@KendoLightHref"
          onerror="window.handleError(this, `default-main.css`)"/>

    <link rel="stylesheet"
          id="kendo-dark"
          href="@KendoDarkHref"
          onerror="window.handleError(this, `default-main-dark.css`)"/>

    <link rel="stylesheet"
          id="custom-light"
          href="@Assets["css/default-main.css"]"/>

    <link rel="stylesheet"
          id="custom-dark"
          href="@Assets["css/default-main-dark.css"]"/>

    <link rel="stylesheet"
          id="local-components"
          href="@Assets["TramTimes.Web.Site.styles.css"]"/>

    <title>TramTimes - South Yorkshire</title>
    <HeadOutlet @rendermode="new InteractiveServerRenderMode(prerender: false)"/>

    <script>
        (function () {
            let scheme = "@_scheme";

            scheme = (scheme === "system")
                ? (window.matchMedia("(prefers-color-scheme: dark)").matches
                    ? "dark"
                    : "light")
                : scheme;

            window.setScheme(scheme);
        })();
    </script>

    <script src="_content/Telerik.UI.for.Blazor/js/telerik-blazor.js" defer></script>
    <script src="_framework/blazor.web.js" defer></script>
</head>

<body>
    <Routes @rendermode="new InteractiveServerRenderMode(prerender: false)"/>
</body>

</html>

@code {
    private string _scheme = "system";
    private string _version = "latest";

    protected override void OnInitialized()
    {
        _scheme = _scheme is "system"
            ? AccessorService.HttpContext?.Request.Cookies[".AspNet.Preference.Scheme"] ?? "system"
            : _scheme;

        if (_scheme is not "dark" and not "light")
            _scheme = "system";

        _version = AppDomain.CurrentDomain.GetAssemblies()
            .FirstOrDefault(predicate: assembly => assembly.GetName().Name == "Telerik.Blazor")?
            .GetCustomAttribute<AssemblyInformationalVersionAttribute>()?.InformationalVersion
            .Split(separator: "+")
            .First() ?? "latest";
    }
}