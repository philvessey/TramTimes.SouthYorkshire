@inject ConsentService ConsentService
@inject LayoutService LayoutService
@inject NavigationManager NavigationService
@inject SchemeService SchemeService
@inject StorageService StorageService
@inject IHttpClientFactory HttpService
@inject IJSRuntime JavascriptService
@inject IMapper MapperService

@page "/trip/{TripId}/{StopId}"
@page "/trip/{TripId}/{StopId}/{Longitude:double}/{Latitude:double}"
@page "/trip/{TripId}/{StopId}/{Longitude:double}/{Latitude:double}/{Zoom:double}"

<PageTitle>@Title</PageTitle>

<TelerikMediaQuery Media="@TelerikMediaQueryDefaults.Columns"
                   OnChange="@(match => LayoutService.SetColumns(match: match))"/>

<TelerikMediaQuery Media="@TelerikMediaQueryDefaults.Rows"
                   OnChange="@(match => LayoutService.SetRows(match: match))"/>

<TelerikMediaQuery Media="@TelerikMediaQueryDefaults.Scheme"
                   OnChange="@(match => OnSchemeChangedAsync(match: match))"/>

@{
    var context = Environment.GetEnvironmentVariable(variable: "ASPIRE_CONTEXT") ?? "Development";
}

<div id="trip" class="@(ConsentService.Consent is true ? "accepted" : "rejected")">

    <!-- #region telerik-map -->

    <div id="trip-telerik-map"
         data-testid="telerik-map"
         tabindex="-1">

        <TelerikMap Center="@MapCenter"
                    Height="100%"
                    MaxZoom="@TelerikMapDefaults.MaxZoom"
                    MinZoom="@TelerikMapDefaults.MinZoom"
                    OnMarkerClick="@OnMapMarkerClickAsync"
                    OnPanEnd="@OnMapPanEndAsync"
                    OnZoomEnd="@OnMapZoomEndAsync"
                    Width="100%"
                    Zoom="@Zoom"
                    @ref="@MapManager">

            <MapControls>
                <MapControlsAttribution Position="MapControlsPosition.BottomRight"/>
                <MapControlsNavigator Enabled="false"/>
                <MapControlsZoom Enabled="false"/>
            </MapControls>

            <MapLayers>
                <MapLayer Type="@MapLayersType.Tile"
                          Attribution="@TelerikMapDefaults.Attribution"
                          Subdomains="@TelerikMapDefaults.Subdomains"
                          UrlTemplate="@TelerikMapDefaults.UrlTemplate"/>

                <MapLayer Type="@MapLayersType.Marker"
                          Data="@MapData"
                          LocationField="@nameof(TelerikStop.Location)">

                    <MapLayerMarkerSettings Template="<span data-testid='marker'>#= dataItem.Platform #</span>">
                        <MapLayerMarkerSettingsTooltip>
                            <Template>

                                @{
                                    var stop = context.DataItem as TelerikStop ?? new TelerikStop();
                                }

                                <div id="trip-telerik-map__tooltip"
                                     data-testid="tooltip">

                                    <div class="services">
                                        <ul>
                                            @{
                                                var points = stop.Points?
                                                    .Take(count: LayoutService.Layout is "columns" ? 5 : 3)
                                                    .Select(selector: point => point)
                                                    .ToList() ?? [];

                                                foreach (var item in points)
                                                {
                                                    var departureTime = item.DepartureDateTime?.ToString(
                                                        format: "HH:mm",
                                                        provider: CultureInfo.InvariantCulture);

                                                    var routeName = item.RouteName?.Replace(
                                                        oldValue: "Line",
                                                        newValue: string.Empty);

                                                    routeName = routeName?
                                                        .ToUpperInvariant()
                                                        .Trim();

                                                    switch (routeName)
                                                    {
                                                        case "BLUE":
                                                            <li class="blue">@departureTime @item.DestinationName</li>
                                                            break;
                                                        case "PURP":
                                                            <li class="purp">@departureTime @item.DestinationName</li>
                                                            break;
                                                        case "TT":
                                                            <li class="tt">@departureTime @item.DestinationName</li>
                                                            break;
                                                        case "YELL":
                                                            <li class="yell">@departureTime @item.DestinationName</li>
                                                            break;
                                                        default:
                                                            <li class="default">@departureTime @item.DestinationName</li>
                                                            break;
                                                    }
                                                }
                                            }
                                        </ul>
                                    </div>
                                </div>
                            </Template>
                        </MapLayerMarkerSettingsTooltip>
                    </MapLayerMarkerSettings>
                </MapLayer>
            </MapLayers>
        </TelerikMap>
    </div>

    <!-- #endregion -->

    <!-- #region banner-horizontal -->

    <div id="trip-banner-horizontal"
         data-testid="banner-horizontal"
         tabindex="-1">

        @{
            if (ConsentService.Consent is true && context is not "Production")
            {
                <img src="https://placehold.co/728x90/0078c8/ffffff?text=Banner"
                     data-testid="placeholder"
                     alt="Banner"/>
            }

            if (ConsentService.Consent is true && context is "Production")
            {
                <div class="_320x50"></div>
                <div class="_468x60"></div>
                <div class="_728x90"></div>
            }
        }
    </div>

    <!-- #endregion -->

    <!-- #region banner-vertical -->

    <div id="trip-banner-vertical"
         data-testid="banner-vertical"
         tabindex="-1">

        @{
            if (ConsentService.Consent is true && context is not "Production")
            {
                <img src="https://placehold.co/160x600/0078c8/ffffff?text=Banner"
                     data-testid="placeholder"
                     alt="Banner"/>
            }

            if (ConsentService.Consent is true && context is "Production")
            {
                <div class="_160x300"></div>
                <div class="_160x600"></div>
            }
        }
    </div>

    <!-- #endregion -->

    <!-- #region telerik-list-view -->

    <div id="trip-telerik-list-view"
         data-testid="telerik-list-view"
         tabindex="-1">

        <TelerikListView EnableLoaderContainer="@TelerikListViewDefaults.EnableLoaderContainer"
                         Height="100%"
                         OnRead="@OnListReadAsync"
                         Width="100%"
                         TItem="@TelerikStopPoint"
                         @ref="@ListManager">

            <Template>
                <div id="trip-telerik-list-view__result"
                     data-testid="result"
                     @onclick="@(_ => OnListChangeAsync(stopId: context.StopId))">

                    <div class="name"
                         data-testid="name">

                        @{
                            var name = context.StopName?
                                .Split(separator: '-')
                                .FirstOrDefault()?
                                .Trim();

                            name = name?
                                .Split(separator: '/')
                                .FirstOrDefault()?
                                .Trim();
                        }

                        @name
                    </div>

                    <div class="direction">
                        @{
                            var direction = context.StopDirection?
                                .Split(separator: '-')
                                .FirstOrDefault()?
                                .Trim();

                            direction = direction?
                                .Split(separator: '/')
                                .FirstOrDefault()?
                                .Trim();
                        }

                        Direction: @direction
                    </div>

                    <div class="services">
                        <ul>
                            @{
                                var departureTime = context.DepartureDateTime?.ToString(
                                    format: "HH:mm",
                                    provider: CultureInfo.InvariantCulture);

                                var routeName = context.RouteName?.Replace(
                                    oldValue: "Line",
                                    newValue: string.Empty);

                                routeName = routeName?
                                    .ToUpperInvariant()
                                    .Trim();

                                switch (routeName)
                                {
                                    case "BLUE":
                                        <li class="blue">@departureTime</li>
                                        break;
                                    case "PURP":
                                        <li class="purp">@departureTime</li>
                                        break;
                                    case "TT":
                                        <li class="tt">@departureTime</li>
                                        break;
                                    case "YELL":
                                        <li class="yell">@departureTime</li>
                                        break;
                                    default:
                                        <li class="default">@departureTime</li>
                                        break;
                                }
                            }
                        </ul>
                    </div>
                </div>
            </Template>
        </TelerikListView>
    </div>

    <!-- #endregion -->

    <!-- #region telerik-skeleton -->

    <div id="trip-telerik-skeleton"
         data-testid="telerik-skeleton"
         hidden="@(!Loading)"
         tabindex="-1">

        @{
            for (var i = 0; i < TelerikSkeletonDefaults.Placeholders; i++)
            {
                <div id="trip-telerik-skeleton__result">
                    <div class="name">
                        <TelerikSkeleton Width="100%"/>
                    </div>

                    <div class="direction">
                        <TelerikSkeleton Width="100%"/>
                    </div>

                    <div class="services">
                        <TelerikSkeleton Width="100%"/>
                    </div>
                </div>
            }
        }
    </div>

    <!-- #endregion -->

    <!-- #region telerik-auto-complete -->

    <div id="trip-telerik-auto-complete"
         data-testid="telerik-auto-complete"
         tabindex="-1">

        <TelerikAutoComplete @bind-value="@Query"
                             DebounceDelay="@TelerikAutoCompleteDefaults.DebounceDelay"
                             Filterable="true"
                             MinLength="@TelerikAutoCompleteDefaults.MinCacheLength"
                             OnBlur="@OnSearchBlurAsync"
                             OnChange="@OnSearchChangeAsync"
                             OnClose="@OnSearchCloseAsync"
                             OnOpen="@OnSearchOpenAsync"
                             OnRead="@OnSearchReadAsync"
                             Placeholder="@TelerikAutoCompleteDefaults.Placeholder"
                             ValueField="@nameof(TelerikStop.Id)"
                             TItem="@TelerikStop">

            <ItemTemplate>
                <div id="trip-telerik-auto-complete__result"
                     data-testid="result">

                    <div class="name"
                         data-testid="name">

                        @{
                            var name = context.Name?
                                .Split(separator: '-')
                                .FirstOrDefault()?
                                .Trim();

                            name = name?
                                .Split(separator: '/')
                                .FirstOrDefault()?
                                .Trim();
                        }

                        @name
                    </div>

                    <div class="direction">
                        @{
                            var direction = context.Direction?
                                .Split(separator: '-')
                                .FirstOrDefault()?
                                .Trim();

                            direction = direction?
                                .Split(separator: '/')
                                .FirstOrDefault()?
                                .Trim();
                        }

                        Direction: @direction
                    </div>

                    <div class="services">
                        <ul>
                            @{
                                var points = context.Points?
                                    .Take(count: 3)
                                    .Select(selector: point => point)
                                    .ToList() ?? [];

                                foreach (var item in points)
                                {
                                    var departureTime = item.DepartureDateTime?.ToString(
                                        format: "HH:mm",
                                        provider: CultureInfo.InvariantCulture);

                                    var routeName = item.RouteName?.Replace(
                                        oldValue: "Line",
                                        newValue: string.Empty);

                                    routeName = routeName?
                                        .ToUpperInvariant()
                                        .Trim();

                                    switch (routeName)
                                    {
                                        case "BLUE":
                                            <li class="blue" title="@item.DestinationName">@departureTime</li>
                                            break;
                                        case "PURP":
                                            <li class="purp" title="@item.DestinationName">@departureTime</li>
                                            break;
                                        case "TT":
                                            <li class="tt" title="@item.DestinationName">@departureTime</li>
                                            break;
                                        case "YELL":
                                            <li class="yell" title="@item.DestinationName">@departureTime</li>
                                            break;
                                        default:
                                            <li class="default" title="@item.DestinationName">@departureTime</li>
                                            break;
                                    }
                                }
                            }
                        </ul>
                    </div>
                </div>
            </ItemTemplate>

            <NoDataTemplate>
                <div id="trip-telerik-auto-complete__unknown">
                    <div class="error">No Stops Found</div>
                    <div class="message">Update Search Query and/or Filter</div>
                </div>
            </NoDataTemplate>
        </TelerikAutoComplete>
    </div>

    <!-- #endregion -->

    <!-- #region navigate-to-location -->

    <div id="trip-navigate-to-location"
         tabindex="-1">

        <NavigateToLocation Longitude="@MapCenter.ElementAt(index: 1)"
                            Latitude="@MapCenter.ElementAt(index: 0)"
                            Page="trip"/>
    </div>

    <!-- #endregion -->

    <!-- #region increase-zoom-level -->

    <div id="trip-increase-zoom-level"
         tabindex="-1">

        <IncreaseZoomLevel Longitude="@MapCenter.ElementAt(index: 1)"
                           Latitude="@MapCenter.ElementAt(index: 0)"
                           Zoom="@Zoom"
                           Page="trip"/>
    </div>

    <!-- #endregion -->

    <!-- #region decrease-zoom-level -->

    <div id="trip-decrease-zoom-level"
         tabindex="-1">

        <DecreaseZoomLevel Longitude="@MapCenter.ElementAt(index: 1)"
                           Latitude="@MapCenter.ElementAt(index: 0)"
                           Zoom="@Zoom"
                           Page="trip"/>
    </div>

    <!-- #endregion -->

    <!-- #region source-code-repository -->

    <div id="trip-source-code-repository"
         tabindex="-1">

        <SourceCodeRepository Url="https://github.com/philvessey/TramTimes.SouthYorkshire"
                              Page="trip"/>
    </div>

    <!-- #endregion -->

    <!-- #region preferred-color-scheme -->

    <div id="trip-preferred-color-scheme"
         tabindex="-1">

        <PreferredColorScheme Scheme="@SchemeService.Scheme"
                              Page="trip"/>
    </div>

    <!-- #endregion -->

    <!-- #region local-storage-consent -->

    <div id="trip-local-storage-consent"
         tabindex="-1">

        <LocalStorageConsent Consent="@ConsentService.Consent"
                             Page="trip"/>
    </div>

    <!-- #endregion -->

</div>